# Database
# PostgreSQL connection string used by Prisma (required)
DATABASE_URL="postgresql://username:password@localhost:5432/apimocker"
TEST_DATABASE_URL="postgresql://username:password@localhost:5432/apimocker_test"
# DIRECT_URL="postgresql://username:password@localhost:5432/apimocker"
# SHADOW_DATABASE_URL="postgresql://username:password@localhost:5432/apimocker_shadow"

# Server
PORT=8000
NODE_ENV=development
ENABLE_ISOLATED_ENVIRONMENTS=false

# Logging
# One of: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# Rate Limiting (applies to write operations: POST, PUT, PATCH, DELETE)
RATE_LIMIT_WINDOW_MS=86400000
RATE_LIMIT_MAX_WRITES=100
