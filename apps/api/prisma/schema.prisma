// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  username String  @unique
  email    String  @unique
  phone    String?
  website  String?
  
  // Nested address object (stored as JSON)
  address  Json?
  
  // Nested company object (stored as JSON)
  company  Json?
  
  // Relationships
  posts    Post[]
  todos    Todo[]
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Post {
  id     Int    @id @default(autoincrement())
  title  String
  body   String

  // Foreign key relationship
  userId Int
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relationships
  comments Comment[]
  likes    Like[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("posts")
}

model Todo {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  completed   Boolean  @default(false)
  
  // Foreign key relationship
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("todos")
}

model Comment {
  id     Int    @id @default(autoincrement())
  name   String
  email  String
  body   String

  // Foreign key relationship
  postId Int
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

model Like {
  id     Int    @id @default(autoincrement())

  // Foreign key relationship
  postId Int
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Optional user tracking (could be anonymous likes)
  userId Int?

  // Timestamps
  createdAt DateTime @default(now())

  @@map("likes")
}

model ApiEnvironment {
  id                String                  @id @default(cuid())
  slug              String                  @unique
  name              String
  apiKeyHash        String                  @unique
  managementKeyHash String                  @unique
  plan              String                  @default("developer")
  active            Boolean                 @default(true)
  requestLimit      Int
  requestsUsed      Int                     @default(0)
  periodStart       DateTime
  periodEnd         DateTime
  burstLimit        Int
  burstRequests     Int                     @default(0)
  burstWindowStart  DateTime
  maxRecords        Int
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  collections       EnvironmentCollection[]

  @@map("api_environments")
}

model EnvironmentCollection {
  environmentId String
  resource      String
  seedData      Json
  data          Json
  nextId        Int
  seedNextId    Int
  version       Int            @default(1)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  environment   ApiEnvironment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@id([environmentId, resource])
  @@map("environment_collections")
}
