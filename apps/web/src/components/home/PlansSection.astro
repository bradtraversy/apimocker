---
import { API_BASE_URL, BETA_URL } from '../../config/site';

const plannedPlans = [
  {
    name: 'Developer environment',
    description: 'A planned isolated environment for demos, portfolios, and side projects that need stable mock data.',
    features: ['25,000 requests per month', '120 requests per minute', '1,000 records per resource', 'Dedicated reset snapshot'],
  },
  {
    name: 'Classroom environment',
    description: 'Planned higher limits for courses, workshops, cohorts, and teaching teams.',
    features: ['100,000 requests per month', '240 requests per minute', '2,000 records per resource', 'Dedicated reset snapshot'],
  },
] as const;
---

<section class="section plans-section" id="plans" aria-labelledby="plans-title">
  <div class="plans-heading">
    <div>
      <div class="eyebrow">Free API now. Private environments later.</div>
      <h2 id="plans-title">Use the shared API today. Isolation is still being built.</h2>
    </div>
    <p>
      Developer and Classroom environments are not available yet. There is no
      signup, billing, public beta, or customer provisioning.
    </p>
  </div>

  <div class="plans-grid">
    <article class="plan-card plan-card-featured">
      <div class="availability-tag">Available now</div>
      <div class="plan-name">Free API</div>
      <h3>$0 <span>public access</span></h3>
      <p>Shared data for learning, examples, tutorials, and frontend prototypes.</p>
      <ul class="check-list compact-list">
        <li>All four public resources</li>
        <li>CRUD, search, filters, and pagination</li>
        <li>Daily data reset</li>
        <li>No account or API key</li>
      </ul>
      <a class="button button-secondary" href={`${API_BASE_URL}/posts`}>Use the free API</a>
    </article>

    {plannedPlans.map((plan) => (
      <article class="plan-card">
        <div class="availability-tag availability-tag-development">Not available yet</div>
        <div class="plan-name">{plan.name}</div>
        <h3>In development <span>planned environment</span></h3>
        <p>{plan.description}</p>
        <ul class="check-list compact-list">
          {plan.features.map((feature) => <li>{feature}</li>)}
        </ul>
        <a
          class="button button-secondary"
          href={BETA_URL}
          target="_blank"
          rel="noopener noreferrer"
        >
          View development details
        </a>
      </article>
    ))}
  </div>
  <p class="plans-note">These are development targets, not active plans or purchase options.</p>
</section>
