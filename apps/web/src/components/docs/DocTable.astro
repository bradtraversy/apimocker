---
import type { DocField } from '../../config/docs';

interface Props {
  fields: DocField[];
  firstColumn?: string;
}

const { fields, firstColumn = 'Name' } = Astro.props;
---

<div class="docs-table-wrap">
  <table class="docs-table">
    <thead>
      <tr>
        <th>{firstColumn}</th>
        <th>Type</th>
        <th>Required</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      {
        fields.map((field) => (
          <tr>
            <td><code>{field.name}</code></td>
            <td>{field.type}</td>
            <td>{field.required}</td>
            <td>{field.description}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
