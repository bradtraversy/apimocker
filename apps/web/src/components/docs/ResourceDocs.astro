---
import type { ResourceDoc } from '../../config/docs';
import { docsApiBaseUrl } from '../../config/docs';
import CodePanel from './CodePanel.astro';
import DocTable from './DocTable.astro';
import EndpointCard from './EndpointCard.astro';

interface Props {
  resource: ResourceDoc;
}

const { resource } = Astro.props;
---

<header class="docs-hero docs-hero-resource">
  <p class="docs-kicker">Resource reference</p>
  <h1>{resource.name}</h1>
  <p>{resource.description}</p>
  <div class="docs-meta">
    <span>{resource.seedCount} records after each reset</span>
    <a href={`${docsApiBaseUrl}/${resource.slug}`} target="_blank" rel="noopener noreferrer">
      View live JSON <span aria-hidden="true">↗</span>
    </a>
  </div>
</header>

<section class="docs-section" id="schema">
  <p class="docs-kicker">Data model</p>
  <h2>{resource.name} schema</h2>
  <p>Responses include the following fields. Read-only values are generated by the API.</p>
  <DocTable fields={resource.fields} firstColumn="Field" />
</section>

<section class="docs-section" id="example">
  <p class="docs-kicker">Example object</p>
  <h2>A complete {resource.name.toLowerCase().replace(/s$/, '')}</h2>
  <CodePanel code={resource.example} id={`${resource.slug}-object`} label="JSON" language="json" />
</section>

<section class="docs-section" id="endpoints">
  <p class="docs-kicker">Endpoints</p>
  <h2>Read and write {resource.name.toLowerCase()}</h2>
  <p>
    Every example uses the shared free API. Replace <code>:id</code> with a numeric record ID.
  </p>

  <div class="endpoint-list">
    {
      resource.endpoints.map((endpoint) => (
        <EndpointCard
          endpoint={endpoint}
          baseUrl={docsApiBaseUrl}
          defaultResponse={resource.example}
        />
      ))
    }
  </div>
</section>
