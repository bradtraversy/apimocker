---
import { SITE_NAME } from '../config/site';

interface Props {
  href?: string;
}

const { href = '/' } = Astro.props;
---

<a class="brand" href={href} aria-label={`${SITE_NAME} home`}>
  <span class="brand-mark" aria-hidden="true"><span>&#123;</span><span>&#125;</span></span>
  <span>{SITE_NAME}</span>
</a>
