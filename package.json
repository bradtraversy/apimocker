{
  "name": "apimocker",
  "version": "1.0.0",
  "description": "A comprehensive fake REST API service for developers to test against",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.12 <23"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @apimocker/api --filter @apimocker/web run dev",
    "dev:api": "pnpm --filter @apimocker/api dev",
    "dev:web": "pnpm --filter @apimocker/web dev",
    "build": "pnpm run build:api && pnpm run build:web",
    "build:api": "pnpm --filter @apimocker/api build",
    "build:web": "pnpm --filter @apimocker/web build",
    "start": "pnpm run start:api",
    "start:api": "pnpm --filter @apimocker/api start",
    "start:web": "pnpm --filter @apimocker/web start",
    "typecheck": "pnpm run typecheck:api && pnpm run typecheck:web",
    "typecheck:api": "pnpm --filter @apimocker/api typecheck",
    "typecheck:web": "pnpm --filter @apimocker/web typecheck",
    "db:generate": "pnpm --filter @apimocker/api db:generate",
    "db:migrate": "pnpm --filter @apimocker/api db:migrate",
    "db:push": "pnpm --filter @apimocker/api db:push",
    "db:seed": "pnpm --filter @apimocker/api db:seed",
    "db:reset": "pnpm --filter @apimocker/api db:reset",
    "db:studio": "pnpm --filter @apimocker/api db:studio",
    "env:create": "pnpm --filter @apimocker/api env:create",
    "env:revoke": "pnpm --filter @apimocker/api env:revoke",
    "test": "pnpm --filter @apimocker/api test",
    "test:watch": "pnpm --filter @apimocker/api test:watch",
    "test:coverage": "pnpm --filter @apimocker/api test:coverage",
    "test:integration": "pnpm --filter @apimocker/api test:integration",
    "test:unit": "pnpm --filter @apimocker/api test:unit",
    "test:environment": "pnpm --filter @apimocker/api test:environment"
  }
}
